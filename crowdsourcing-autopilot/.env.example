# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_WEBHOOK_UPWORK=https://discord.com/api/webhooks/xxx/yyy

# Upwork
UPWORK_CLIENT_ID=your_upwork_client_id
UPWORK_CLIENT_SECRET=your_upwork_client_secret

# Freelancer.com
FREELANCER_CLIENT_ID=your_freelancer_client_id
FREELANCER_CLIENT_SECRET=your_freelancer_client_secret
FREELANCER_ACCESS_TOKEN=your_freelancer_access_token

# Groq (提案文生成・スコアリング)
GROQ_API_KEY=your_groq_api_key

# CrowdWorks
CROWDWORKS_SESSION=your_crowdworks_session_cookie

# Lancers
LANCERS_SESSION=your_lancers_session_cookie

# Coconala
COCONALA_COOKIE=your_coconala_cookie

# Fiverr
FIVERR_COOKIE=your_fiverr_cookie

# Scale AI
SCALE_AI_SESSION=your_scale_ai_session
SCALE_AI_BASE_URL=https://remotasks.example

# Remotasks
REMOTASKS_COOKIE=your_remotasks_cookie
REMOTASKS_API_URL=https://remotasks.example/api

# DataAnnotation
DATAANNOTATION_COOKIE=your_dataannotation_cookie
DATAANNOTATION_API_URL=https://dataannotation.tech/api

# Lightpanda (オプション: ヘッドレスブラウザ)
LIGHTPANDA_BIN=/usr/local/bin/lightpanda
