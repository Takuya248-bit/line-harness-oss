{
  "name": "line-oss-crm",
  "version": "0.4.0",
  "private": true,
  "description": "Open-source LINE Official Account CRM/marketing automation",
  "scripts": {
    "dev:worker": "pnpm --filter worker dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "deploy:worker": "pnpm --filter worker deploy",
    "deploy:web": "pnpm --filter web build",
    "db:migrate": "wrangler d1 execute line-crm --file=packages/db/schema.sql",
    "db:migrate:local": "wrangler d1 execute line-crm --file=packages/db/schema.sql --local"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "js-yaml": "^4.1.1",
    "puppeteer": "^24.40.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.0.0"
  }
}
