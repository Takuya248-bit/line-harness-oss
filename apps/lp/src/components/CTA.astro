---
---

<section id="contact" class="py-20 bg-gradient-to-br from-cyan-500 via-cyan-600 to-emerald-500 relative overflow-hidden">
  <!-- Background decorations -->
  <div class="absolute top-0 left-0 w-64 h-64 bg-white/10 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-white/5 rounded-full blur-3xl translate-x-1/3 translate-y-1/3"></div>

  <div class="relative max-w-3xl mx-auto px-4 text-center">
    <h2 class="text-2xl md:text-4xl font-bold text-white mb-4">
      まずは無料相談から始めませんか?
    </h2>
    <p class="text-cyan-100 mb-10 leading-relaxed">
      「うちのビジネスでも使える?」「Lステップから移行できる?」<br class="hidden md:block" />
      どんな疑問でもお気軽にご相談ください。オンラインで30分、無料でお答えします。
    </p>

    <div class="bg-white rounded-2xl p-8 md:p-10 shadow-2xl max-w-lg mx-auto">
      <h3 class="text-lg font-bold mb-6">お問い合わせフォーム</h3>

      <form action="#" method="POST" class="space-y-4 text-left">
        <div>
          <label for="name" class="block text-sm font-semibold text-gray-700 mb-1">お名前</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition-all text-sm"
            placeholder="山田 太郎"
          />
        </div>

        <div>
          <label for="business" class="block text-sm font-semibold text-gray-700 mb-1">業種</label>
          <select
            id="business"
            name="business"
            required
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition-all text-sm appearance-none bg-white"
          >
            <option value="">選択してください</option>
            <option value="beauty">美容室・サロン</option>
            <option value="restaurant">飲食店・カフェ</option>
            <option value="school">スクール・教室</option>
            <option value="clinic">クリニック・整体院</option>
            <option value="retail">小売・EC</option>
            <option value="realestate">不動産</option>
            <option value="other">その他</option>
          </select>
        </div>

        <div>
          <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">メールアドレス</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition-all text-sm"
            placeholder="info@example.com"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-semibold text-gray-700 mb-1">ご相談内容(任意)</label>
          <textarea
            id="message"
            name="message"
            rows="3"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition-all text-sm resize-none"
            placeholder="現在のLINE運用の状況や、実現したいことなどをお聞かせください。"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full btn-primary justify-center"
        >
          無料相談を予約する
        </button>

        <p class="text-xs text-gray-500 text-center">
          送信後、1営業日以内にご連絡いたします。
        </p>
      </form>
    </div>

    <!-- LINE Add Friend (alternative CTA) -->
    <div class="mt-10">
      <p class="text-cyan-100 text-sm mb-3">LINE友だち追加で無料診断も受けられます</p>
      <a
        href="#"
        class="inline-flex items-center gap-2 bg-[#06C755] hover:bg-[#05b34c] text-white font-bold px-8 py-4 rounded-full transition-colors shadow-lg"
      >
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.271.173-.508.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
        </svg>
        LINE友だち追加
      </a>
    </div>
  </div>
</section>
