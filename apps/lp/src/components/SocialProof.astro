---
const stats = [
  {
    value: '50+',
    unit: '件',
    label: '構築実績',
    sublabel: '自動化シナリオ数',
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.745 3.745 0 011.043 3.296A3.745 3.745 0 0121 12z" /></svg>`,
  },
  {
    value: '0円',
    unit: '',
    label: '月額ツール費用',
    sublabel: 'ランニングコスト',
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  },
  {
    value: '5日〜',
    unit: '',
    label: '最短構築期間',
    sublabel: 'スピード納品',
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  },
];

const testimonials = [
  {
    quote: '毎月のLINEツール費用がゼロになったのが大きい。浮いた分を広告に回せています。',
    name: 'A様',
    role: '東京都・美容室経営',
    avatar: 'woman',
  },
  {
    quote: '有料ツールと同じことができて月額タダ。正直もっと早く知りたかった。',
    name: 'B様',
    role: '大阪府・飲食店経営',
    avatar: 'man',
  },
];
---

<section id="social-proof" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4">

    <!-- Section Header -->
    <p class="text-cyan-600 font-semibold text-center mb-2">Voice</p>
    <h2 class="section-title">選ばれる理由</h2>

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mt-12 mb-16">
      {stats.map((stat) => (
        <div class="text-center p-8 rounded-2xl bg-gray-50 border border-gray-100">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-gradient-to-br from-cyan-100 to-emerald-100 text-cyan-600 mb-4">
            <Fragment set:html={stat.icon} />
          </div>
          <div class="flex items-baseline justify-center gap-1 mb-1">
            <span class="text-4xl md:text-5xl font-extrabold bg-gradient-to-r from-cyan-600 to-emerald-500 bg-clip-text text-transparent">
              {stat.value}
            </span>
            {stat.unit && (
              <span class="text-lg font-semibold text-gray-600">{stat.unit}</span>
            )}
          </div>
          <p class="text-gray-900 font-semibold text-lg">{stat.label}</p>
          <p class="text-gray-500 text-sm mt-1">{stat.sublabel}</p>
        </div>
      ))}
    </div>

    <!-- Testimonials -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {testimonials.map((t) => (
        <div class="relative bg-white rounded-2xl border border-gray-200 p-8 shadow-sm hover:shadow-md transition-shadow">
          <!-- Stars -->
          <div class="flex gap-0.5 mb-4">
            {[...Array(5)].map(() => (
              <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="text-gray-700 text-lg leading-relaxed mb-6">
            「{t.quote}」
          </blockquote>

          <!-- Author -->
          <div class="flex items-center gap-3">
            {t.avatar === 'woman' ? (
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-pink-200 to-pink-300 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-pink-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                </svg>
              </div>
            ) : (
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-200 to-blue-300 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                </svg>
              </div>
            )}
            <div>
              <p class="text-gray-900 font-semibold text-sm">{t.name}</p>
              <p class="text-gray-500 text-sm">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
