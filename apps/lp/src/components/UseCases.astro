---
const useCases = [
  {
    id: 'beauty',
    label: '美容室',
    icon: '✂️',
    title: '美容室・サロンの活用例',
    scenario: [
      '友だち追加 → 初回限定クーポン自動配信',
      '来店後 → お礼メッセージ + 次回予約促進',
      '30日後 → リマインド配信「そろそろカットの時期です」',
      'スコアリング → 来店頻度で VIP顧客を自動識別',
      'VIP顧客 → 限定メニューの先行案内',
    ],
    result: '来店後のフォロー自動化で、次回予約率が向上。スタッフの連絡業務が月20時間以上削減。',
  },
  {
    id: 'restaurant',
    label: '飲食店',
    icon: '🍽️',
    title: '飲食店・カフェの活用例',
    scenario: [
      '友だち追加 → ドリンク1杯無料クーポン配信',
      '曜日別 → ランチタイムにおすすめメニュー配信',
      'アンケート → 好みの料理ジャンルをヒアリング',
      'セグメント → 好みに合わせた新メニュー情報を配信',
      '誕生月 → バースデー特典を自動配信',
    ],
    result: '誕生日クーポンの自動配信で再来店率が向上。好み別セグメント配信で、ブロック率の低減を実現。',
  },
  {
    id: 'english',
    label: '英会話教室',
    icon: '📚',
    title: '英会話教室・スクールの活用例',
    scenario: [
      '友だち追加 → 無料体験レッスンの案内を自動配信',
      'ステップ配信 → 英語学習のコツを7日間連続配信',
      'アンケート → 英語レベル・目的をヒアリング',
      'セグメント → レベル別のクラス案内を配信',
      'AI自動応答 → 英語の質問にAIが即座に回答',
    ],
    result: 'ステップ配信で体験申込までの導線を自動化。入会後のフォロー配信で退会率の低減に貢献。',
  },
];
---

<section id="usecases" class="py-20 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4">
    <p class="text-cyan-600 font-semibold text-center mb-2">Use Cases</p>
    <h2 class="section-title">業種別の活用例</h2>
    <p class="section-subtitle">あなたのビジネスではどう使える? 具体的な活用シナリオをご紹介。</p>

    <!-- Tab buttons -->
    <div class="flex justify-center gap-3 mb-10" id="usecase-tabs">
      {useCases.map((uc, i) => (
        <button
          data-tab={uc.id}
          class={`flex items-center gap-1.5 px-4 py-2 rounded-full text-xs sm:text-sm font-semibold transition-all ${i === 0 ? 'bg-cyan-500 text-white shadow-lg' : 'bg-white text-gray-600 border border-gray-200 hover:border-cyan-300'}`}
        >
          <span>{uc.icon}</span>
          <span>{uc.label}</span>
        </button>
      ))}
    </div>

    <!-- Tab contents -->
    <div id="usecase-contents">
      {useCases.map((uc, i) => (
        <div data-content={uc.id} class={`${i !== 0 ? 'hidden' : ''}`}>
          <div class="bg-white rounded-2xl p-8 md:p-10 shadow-sm border border-gray-100 max-w-3xl mx-auto">
            <h3 class="text-xl font-bold mb-6 flex items-center gap-2">
              <span class="text-2xl">{uc.icon}</span>
              {uc.title}
            </h3>

            <div class="space-y-4 mb-8">
              {uc.scenario.map((step, idx) => (
                <div class="flex items-start gap-3">
                  <span class="flex-shrink-0 w-7 h-7 rounded-full bg-cyan-100 text-cyan-600 flex items-center justify-center text-sm font-bold">
                    {idx + 1}
                  </span>
                  <p class="text-sm text-gray-700 pt-0.5">{step}</p>
                </div>
              ))}
            </div>

            <div class="bg-emerald-50 rounded-xl p-4 border border-emerald-100">
              <p class="text-sm font-semibold text-emerald-700 flex items-start gap-2">
                <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                {uc.result}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('#usecase-tabs button');
    const contents = document.querySelectorAll('#usecase-contents [data-content]');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const targetId = tab.getAttribute('data-tab');

        // Update tab styles
        tabs.forEach((t) => {
          t.classList.remove('bg-cyan-500', 'text-white', 'shadow-lg');
          t.classList.add('bg-white', 'text-gray-600', 'border', 'border-gray-200');
        });
        tab.classList.remove('bg-white', 'text-gray-600', 'border', 'border-gray-200');
        tab.classList.add('bg-cyan-500', 'text-white', 'shadow-lg');

        // Show target content
        contents.forEach((c) => {
          if (c.getAttribute('data-content') === targetId) {
            c.classList.remove('hidden');
          } else {
            c.classList.add('hidden');
          }
        });
      });
    });
  });
</script>
